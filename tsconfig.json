{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@ports/*": ["src/application/ports/*"],
      "@usecases/*": ["src/application/usecases/*"],
      "@common/*": ["src/domain/common/*"],
      "@workLog/*": ["src/domain/workLog/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@interfaces/*": ["src/interfaces/*"],
      "@types/*": ["src/types/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
