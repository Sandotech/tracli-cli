{
  "name": "tracli-cli",
  "version": "0.1.0",
  "description": "The zero-friction work logger for terminal-first developers.",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "tracli": "dist/interfaces/cli/bin.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/interfaces/cli/bin.ts"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
